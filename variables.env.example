# Root media library scanned for channels.
LIBRARY_DIR=/library

# HTTP listen port used by uvicorn inside the container.
REPLAY_PORT=8090

# Library rescan interval in seconds.
REPLAY_SCAN_INTERVAL=60

# HLS output tuning.
HLS_SEGMENT_TIME=4
HLS_LIST_SIZE=20

# Enable transcoding for all channels (true/false).
TRANSCODE_ENABLED=false

# Used only when transcoding is enabled.
VIDEO_BITRATE=4000k
AUDIO_BITRATE=128k

# Number of threads each ffmpeg transcode process may use.
FFMPEG_THREADS=2
